# Env-driven first-run bootstrap for the QA container.
# Copy to `orbix.env` ON THE BOX (gitignored), fill in the secrets, then deploy.
# deploy.ps1 / deploy.sh pass this file to `docker run --env-file`.
#
# On a fresh DB the app self-bootstraps org + company + branch + the company-wide
# `rootadmin`. On an already-bootstrapped DB it's a no-op.

ORBIX_BOOTSTRAP_ENABLED=true

# Organisation
ORBIX_BOOTSTRAP_ORG_NAME=Orbix
ORBIX_BOOTSTRAP_ORG_LEGAL_NAME=Orbix Ltd
ORBIX_BOOTSTRAP_ORG_CURRENCY=TZS
ORBIX_BOOTSTRAP_ORG_COUNTRY=TZ

# Company
ORBIX_BOOTSTRAP_COMPANY_CODE=COM
ORBIX_BOOTSTRAP_COMPANY_NAME=Orbix QA
ORBIX_BOOTSTRAP_COMPANY_TIMEZONE=Africa/Dar_es_Salaam

# Branch (operating branch; rootadmin itself is company-wide / no default branch)
ORBIX_BOOTSTRAP_BRANCH_CODE=HQ
ORBIX_BOOTSTRAP_BRANCH_NAME=Head Office

# rootadmin — company-wide superadmin. Password is read from here at bootstrap
# AND by the reset endpoint. Must be >= 12 chars and not a common placeholder,
# or the app refuses to start.
ORBIX_BOOTSTRAP_ADMIN_USERNAME=rootadmin
ORBIX_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_to_a_strong_secret
ORBIX_BOOTSTRAP_ADMIN_DISPLAY_NAME=Root Administrator

# Shared secret for POST /api/v1/setup/reset-rootadmin-password (X-Bootstrap-Token).
# Blank = endpoint disabled. The endpoint never accepts a password — it only
# re-applies ORBIX_BOOTSTRAP_ADMIN_PASSWORD above.
ORBIX_BOOTSTRAP_RESET_TOKEN=CHANGE_ME_to_a_random_token
