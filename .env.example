# Local development environment variables.
# Copy to `.env` (gitignored) and adjust as needed.

# Database — default profile uses MySQL. Switch with SPRING_PROFILES_ACTIVE.
SPRING_PROFILES_ACTIVE=local,mysql

# MySQL
MYSQL_ROOT_PASSWORD=rootlocal
MYSQL_PASSWORD=orbixlocal
DB_URL=jdbc:mysql://localhost:3306/orbix_erp?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USER=orbix
DB_PASSWORD=orbixlocal

# PostgreSQL (only used when SPRING_PROFILES_ACTIVE includes 'postgres')
POSTGRES_PASSWORD=orbixlocal

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Meilisearch
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=meili-local-key

# MinIO
MINIO_ROOT_PASSWORD=orbixlocal

# JWT — development uses an ephemeral in-memory key.
# Production loads RS256 keys from the secret store; never put production secrets here.
JWT_SIGNING_MODE=dev-in-memory
